# ============================================================================
# Local WordPress Docker Environment
# ============================================================================

# WordPress
WORDPRESS_PORT=8080
WORDPRESS_DB_HOST=db:3306
WORDPRESS_DB_NAME=hopp_wordpress
WORDPRESS_DB_USER=hopp_user
WORDPRESS_DB_PASSWORD=change_me
WORDPRESS_TABLE_PREFIX=wp_
WORDPRESS_DEBUG=1
WORDPRESS_VIRTUAL_HOST=humansofphnompenh.local

# MySQL
MYSQL_DATABASE=hopp_wordpress
MYSQL_USER=hopp_user
MYSQL_PASSWORD=change_me
MYSQL_ROOT_PASSWORD=change_me_root

# Optional local WordPress bootstrap values.
# These are placeholders only. Do not use real production credentials here.
WORDPRESS_LOCAL_URL=http://localhost:8080
WORDPRESS_LOCAL_TITLE="Humans of Phnom Penh Local"
WORDPRESS_LOCAL_ADMIN_USER=admin
WORDPRESS_LOCAL_ADMIN_PASSWORD=change_me_admin
WORDPRESS_LOCAL_ADMIN_EMAIL=admin@example.com

# Optional preview values.
# Use these only in a preview-specific env file such as .env.gcp.
DOMAIN_NAME=
WORDPRESS_PUBLIC_URL=
WORDPRESS_PUBLIC_PORT=80
LETSENCRYPT_EMAIL=
WORDPRESS_ENVIRONMENT_TYPE=production
HOPP_ENABLE_DEMO_SEED=false

# Optional production backup settings.
# Use these only in .env.gcp on the VM.
HOPP_BACKUP_DIR=
HOPP_BACKUP_RETENTION_DAYS=14

# Optional mail settings.
# Leave these blank locally unless you are intentionally testing SMTP.
HOPP_ADMIN_NOTIFICATION_EMAIL=
HOPP_MAIL_FROM_ADDRESS=
HOPP_MAIL_FROM_NAME="Humans of Phnom Penh"
HOPP_MAIL_TRANSPORT=
HOPP_SMTP_HOST=
HOPP_SMTP_PORT=465
HOPP_SMTP_SECURE=ssl
HOPP_SMTP_USER=
HOPP_SMTP_PASSWORD=
HOPP_SMTP_AUTO_TLS=false

# Theme
WP_THEME_SLUG=hopp
