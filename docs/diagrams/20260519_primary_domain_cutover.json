    { "from_node": "cutover_inputs", "from_port": "ops_mailbox", "to_node": "env_update", "to_port": "ops_mailbox" },
    { "from_node": "backup_script", "from_port": "backup_bundle", "to_node": "env_update", "to_port": "backup_bundle" },
    { "from_node": "env_update", "from_port": "updated_env", "to_node": "deploy_stack", "to_port": "updated_env" },
    { "from_node": "env_update", "from_port": "updated_env", "to_node": "issue_cert", "to_port": "updated_env" },
    { "from_node": "deploy_stack", "from_port": "running_stack", "to_node": "smoke_test", "to_port": "running_stack" },
    { "from_node": "issue_cert", "from_port": "tls_ready", "to_node": "smoke_test", "to_port": "tls_ready" },
    { "from_node": "dns_owner", "from_port": "domain_points_to_vm", "to_node": "smoke_test", "to_port": "domain_points_to_vm" },
    { "from_node": "smoke_test", "from_port": "smoke_pass", "to_node": "manual_verify", "to_port": "smoke_pass" },
    { "from_node": "aba_whitelist", "from_port": "aba_domain_allowed", "to_node": "manual_verify", "to_port": "aba_domain_allowed" },
    { "from_node": "cutover_inputs", "from_port": "ops_mailbox", "to_node": "manual_verify", "to_port": "ops_mailbox" }
  ]
}
